# Required: your backend API base URL
VITE_API_BASE_URL=https://your-backend-project.vercel.app/api/v1

# Required for iOS: your App Store URL (e.g. https://apps.apple.com/app/id<YOUR_APP_ID>)
# Android uses Play Store automatically with the install referrer for token passing.
# iOS note: the token cannot survive a fresh iOS install — the App Store has no referrer API.
VITE_APP_STORE_URL=https://apps.apple.com/app/id<YOUR_APP_ID>

# Optional: must match PENDING_TTL_SECONDS in the backend .env (default: 60)
VITE_PENDING_TTL_SECONDS=60
